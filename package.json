{
    "private": true,
    "scripts": {
        "build:css:core": "npx @tailwindcss/cli -i ./resources/css/core.css -o ./resources/dist/css/core.css --minify",
        "build:css:playground": "npx @tailwindcss/cli -i ./resources/css/playground.css -o ./resources/dist/css/playground.css --minify",
        "build:css:components": "node scripts/build-component-css.mjs",
        "build:css:playground-bundles": "node scripts/build-playground-bundles.mjs",
        "build:css:legacy": "npx @tailwindcss/cli -i ./resources/css/plugin.css -o ./resources/dist/filament-flex-fields.css --minify",
        "build:css": "npm run build:css:core && npm run build:css:playground && npm run build:css:components && npm run build:css:playground-bundles",
        "build:js": "node scripts/build-component-js.mjs && node scripts/build-asset-injector-js.mjs && node scripts/build-rich-editor-support-js.mjs && node scripts/build-skeleton-demo-js.mjs",
        "test:js": "node --import ./tests/js/register-svg-loader.mjs --test tests/js/**/*.test.mjs",
        "test:e2e": "playwright test",
        "test:e2e:coordinator": "playwright test tests/e2e/field-smoke.spec.mjs",
        "test:e2e:smoke": "playwright test tests/e2e/field-smoke.spec.mjs",
        "test:e2e:playground": "playwright test tests/e2e/playground-*.spec.mjs",
        "test:e2e:playground-skeleton": "playwright test tests/e2e/playground-skeleton-injector.spec.mjs",
        "test:e2e:rich-editor": "playwright test tests/e2e/playground-flex-rich-editor.spec.mjs",
        "test:assets": "npm run build && npm run test:js && npm run test:e2e:coordinator",
        "docs:sanitize": "node scripts/sanitize-docs-for-mintlify.mjs",
        "docs:fix-links": "node scripts/fix-docs-internal-links.mjs",
        "docs:fix-titles": "node scripts/fix-docs-mintlify-titles.mjs",
        "docs:dev": "mintlify dev",
        "docs:build": "mintlify build",
        "build": "npm run build:css && npm run build:js && node scripts/generate-bundle-summary.mjs",
        "check:budgets": "node scripts/check-bundle-budgets.mjs",
        "compare:budgets": "node scripts/compare-bundle-metrics.mjs",
        "audit:components": "node scripts/audit-components.mjs",
        "watch:css": "npx @tailwindcss/cli -i ./resources/css/core.css -o ./resources/dist/css/core.css --watch"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@tailwindcss/cli": "^4.1.0",
        "@tiptap/core": "^3.27.1",
        "@tiptap/extension-youtube": "^3.27.1",
        "esbuild": "^0.25.0",
        "tailwindcss": "^4.1.0"
    },
    "dependencies": {
        "@gravity-ui/icons": "^2.18.0",
        "@internationalized/date": "^3.8.2",
        "@zxing/browser": "^0.1.5",
        "@zxing/library": "^0.21.3",
        "emoji-picker-element": "^1.29.1",
        "libphonenumber-js": "^1.13.6",
        "nouislider": "^15.8.1",
        "number-flow": "^0.5.8"
    }
}
